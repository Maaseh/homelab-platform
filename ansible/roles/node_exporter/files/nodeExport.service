[Unit]
Description=Node export for Prometheus
Wants=network.target
After=network.target

[Service]
Type=simple
User=nodeuser
ExecStart=/usr/local/bin/node_exporter
Restart=on-failure
RestartSec=5s
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
